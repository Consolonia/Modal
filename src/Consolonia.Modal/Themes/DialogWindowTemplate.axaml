<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialog="clr-namespace:Consolonia.Modal"
        xmlns:brushes="https://github.com/consolonia">
    <Styles.Resources>
        <Thickness x:Key="ConsoloniaDialogWindowBorderMargin">1,0</Thickness>
        <ControlTheme x:Key="{x:Type dialog:DialogWindow}"
                      TargetType="dialog:DialogWindow">
            <Setter Property="Background"
                    Value="{DynamicResource ThemeBackgroundBrush}" />
            <Setter Property="Foreground"
                    Value="{DynamicResource ThemeForegroundBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="IsCloseButtonVisible"
                    Value="True" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <!--Centered layout-->
                        <!--Panel shade Mode=Shaded-->
                        <Border Background="{DynamicResource ThemeShadeBrush}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                x:Name="PART_SHADOW">
                            <Border BorderBrush="{DynamicResource ThemeTransparentBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}">
                                <Control
                                    Width="{Binding Path=ContentSize.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding Path=ContentSize.Height, RelativeSource={RelativeSource TemplatedParent}}"
                                    IsHitTestVisible="False"
                                    Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Border>

                        <!--Panel-->
                        <Panel Background="{DynamicResource DialogWindowOuterBorderBackgroundBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                            <Border BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}"
                                    Classes="DialogWindowBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <Control
                                    Width="{Binding Path=ContentSize.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding Path=ContentSize.Height, RelativeSource={RelativeSource TemplatedParent}}"
                                    IsHitTestVisible="False"
                                    Margin="{TemplateBinding Padding}" />
                            </Border>
                            
                            <dialog:DialogWindowHeader Title="{TemplateBinding Title}"
                                                       Icon="{TemplateBinding Icon}"
                                                       IsCloseButtonVisible="{TemplateBinding IsCloseButtonVisible}"
                                                       BorderBrush="{TemplateBinding BorderBrush}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       VerticalAlignment="Top" />
                        </Panel>
                        
                        <!--Content-->
                        <Panel Margin="2,1,2,1">
                                <ContentPresenter Name="PART_ContentPresenter"
                                                  Margin="{DynamicResource ConsoloniaDialogWindowBorderMargin}"
                                                  Padding="{TemplateBinding Padding}"
                                                  BorderThickness="{TemplateBinding BorderThickness}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Content="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}" />
                        </Panel>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Styles.Resources>
</Styles>