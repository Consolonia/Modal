<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:modal="clr-namespace:Consolonia.Modal">
    <Styles.Resources>
        <Thickness x:Key="ConsoloniaModalWindowBorderMargin">1,0</Thickness>
        <ControlTheme x:Key="{x:Type modal:ModalWindow}"
                      TargetType="modal:ModalWindow">
            <Setter Property="Background"
                    Value="{DynamicResource ThemeBackgroundBrush}" />
            <Setter Property="Foreground"
                    Value="{DynamicResource ThemeForegroundBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Margin"
                    Value="0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="IsCloseButtonVisible"
                    Value="True" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <!--Centered layout-->
                        <!--Panel shade Mode=Shaded-->
                        <Border Background="{DynamicResource ThemeShadeBrush}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                x:Name="PART_SHADOW">
                            <Border BorderBrush="{DynamicResource ThemeTransparentBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="{DynamicResource ConsoloniaModalWindowBorderMargin}">
                                <Control
                                    Width="{Binding Path=ContentSize.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding Path=ContentSize.Height, RelativeSource={RelativeSource TemplatedParent}}"
                                    IsHitTestVisible="False"
                                    Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Border>

                        <!--Panel-->
                        <Panel Background="{DynamicResource ModalWindowOuterBorderBackgroundBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                            <!-- ReSharper disable Xaml.StyleClassNotFound -->
                            <Border BorderThickness="{TemplateBinding BorderThickness}"
                                    Margin="{DynamicResource ConsoloniaModalWindowBorderMargin}"
                                    Classes="ModalWindowBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}">
                                <!-- ReSharper restore Xaml.StyleClassNotFound -->
                                <Control
                                    Width="{Binding Path=ContentSize.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                    Height="{Binding Path=ContentSize.Height, RelativeSource={RelativeSource TemplatedParent}}"
                                    IsHitTestVisible="False"
                                    Margin="{TemplateBinding Padding}" />
                            </Border>

                            <modal:ModalWindowHeader Title="{TemplateBinding Title}"
                                                     Icon="{TemplateBinding Icon}"
                                                     IsCloseButtonVisible="{TemplateBinding IsCloseButtonVisible}"
                                                     BorderBrush="{TemplateBinding BorderBrush}"
                                                     Foreground="{TemplateBinding Foreground}"
                                                     VerticalAlignment="Top" />
                        </Panel>

                        <!--Content-->
                        <Panel Margin="2,1,2,1">
                            <Grid Background="{TemplateBinding Background}"
                                  Margin="2,1" />
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Margin="{DynamicResource ConsoloniaModalWindowBorderMargin}"
                                              Padding="{TemplateBinding Padding}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Content="{TemplateBinding Content}"
                                              Foreground="{TemplateBinding Foreground}" />
                        </Panel>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Styles.Resources>
</Styles>